generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  name         String?
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Hero {
  id                Int      @id @default(1)
  title             String
  subtitle          String?
  description       String?  @db.Text
  yearsOfExperience String?
  countries         String?
  award             String?
  profile           String?
  updatedAt         DateTime @default(now()) @updatedAt
}

model About {
  id                  Int      @id @default(1)
  title               String
  description         String   @db.Text
  philosophy          String   @db.Text
  highlightedPositions HighlightedPosition[]
  updatedAt           DateTime @default(now()) @updatedAt
  activities          Activity[]
}

model HighlightedPosition {
  id          Int     @id @default(autoincrement())
  title       String
  company     String
  about       About?  @relation(fields: [aboutId], references: [id])
  aboutId     Int?
}

model Activity {
    id      Int     @id @default(autoincrement())
    label   String
    icon    String  // image url
    about   About?  @relation(fields: [aboutId], references: [id])
    aboutId Int?
}

model Experience {
  id          Int       @id @default(autoincrement())
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String    @db.Text
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

model Event {
  id            Int       @id @default(autoincrement())
  title         String
  role          String
  date          DateTime
  location      String
  description   String    @db.Text
  coverImage    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
}

model Gallery {
  id        Int      @id @default(autoincrement())
  image  String
  caption   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Contact {
  id        Int      @id @default(1)
  email     String
  phone     String?
  linkedin  String?
  github    String?
  twitter   String?
  updatedAt DateTime @default(now()) @updatedAt
}
